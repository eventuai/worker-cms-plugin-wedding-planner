# Local development variables for the wedding-planner plugin Worker.
# Copy this file to `.dev.vars` and fill in real values. `.dev.vars` is
# gitignored and never committed; values here override `[vars]` in wrangler.toml
# while running `wrangler dev`.

# Base URL of the CMS Worker the plugin reads/writes through ({CMS_URL}/__cms/*).
# Point this at your locally running CMS dev server (default port 8787).
CMS_URL=http://localhost:8787

# Shared secret the CMS forwards on every hook/admin call and the plugin sends
# back on every Plugin API write. MUST match the secret the CMS generated for
# this plugin under Admin → Plugins, or every plugin call 403s.
PLUGIN_SECRET=replace-with-the-cms-plugin-secret
