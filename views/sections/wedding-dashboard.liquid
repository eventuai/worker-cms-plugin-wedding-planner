<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ weddingsHref }}">{{ "wedding_planner.nav.weddings_back" | t }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ weddingName }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ weddingDate }}{% if daysToGo != null %} · <span class="font-semibold text-rose-700">{{ "wedding_planner.views.wedding_dashboard.days_to_go_prefix" | t }} {{ daysToGo }} {{ "wedding_planner.views.wedding_dashboard.days_to_go_suffix" | t }}</span>{% endif %}</p>
  </div>
  <div class="inline-flex items-center gap-3">
    {% if editHref != blank %}<a class="text-sm text-indigo-600 hover:text-indigo-800" href="{{ editHref }}">{{ "wedding_planner.views.wedding_dashboard.edit" | t }}</a>{% endif %}
    {% if deleteHref != blank %}<a class="text-sm text-red-600 hover:text-red-700" href="{{ deleteHref }}">{{ "wedding_planner.views.wedding_dashboard.delete" | t }}</a>{% endif %}
  </div>
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash | t }}</p>{% endif %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
  <a class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 block hover:bg-indigo-50" href="{{ checklistHref }}">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">{{ "wedding_planner.nav.checklist" | t }}</p>
    <p class="text-2xl font-bold text-gray-900">{{ taskDone }} / {{ taskTotal }}</p>
    <p class="text-sm text-gray-500 mb-3">{{ "wedding_planner.views.wedding_dashboard.tasks_done" | t }}</p>
    <div class="rounded-full bg-gray-100" style="height:8px"><div class="rounded-full" style="height:8px;width:{{ taskPercent }}%;background-color:#4f46e5"></div></div>
  </a>
  <a class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 block hover:bg-indigo-50" href="{{ budgetHref }}">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">{{ "wedding_planner.nav.budget" | t }}</p>
    <p class="text-2xl font-bold text-gray-900">$ {{ budgetPaid }}</p>
    <p class="text-sm text-gray-500 mb-3">{{ "wedding_planner.views.wedding_dashboard.paid_of" | t }} $ {{ budgetTotal }} · {{ "wedding_planner.views.wedding_dashboard.remaining" | t }} $ {{ budgetRemaining }}</p>
    <div class="rounded-full bg-gray-100" style="height:8px"><div class="rounded-full" style="height:8px;width:{{ budgetPercent }}%;background-color:#059669"></div></div>
  </a>
  <a class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 block hover:bg-indigo-50" href="{{ rundownHref }}">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">{{ "wedding_planner.nav.rundown" | t }}</p>
    <p class="text-2xl font-bold text-gray-900">{{ rundownCount }}</p>
    <p class="text-sm text-gray-500">{{ "wedding_planner.views.wedding_dashboard.rundown_items" | t }}</p>
  </a>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200">
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">{{ "wedding_planner.views.wedding_dashboard.upcoming_tasks" | t }}</h2>
    <a class="text-sm text-indigo-600 hover:text-indigo-800" href="{{ checklistHref }}">{{ "wedding_planner.views.wedding_dashboard.view_all" | t }}</a>
  </div>
  <div class="divide-y divide-gray-100">
    {% for task in upcoming %}
      <div class="flex items-center justify-between gap-4 px-6 py-3">
        <div class="flex items-center gap-3 min-w-0">
          <span class="inline-block rounded-full" style="width:10px;height:10px;background-color:{{ task.categoryColor }}"></span>
          <span class="text-sm text-gray-700 truncate">{{ task.name }}</span>
        </div>
        <div class="flex items-center gap-3 whitespace-nowrap">
          <span class="text-xs text-gray-500">{{ task.categoryLabelKey | t }}</span>
          <span class="text-xs font-semibold text-rose-700">{{ task.dueLabel }}</span>
        </div>
      </div>
    {% else %}
      <p class="px-6 py-10 text-center text-sm text-gray-400">{{ "wedding_planner.views.wedding_dashboard.no_upcoming" | t }}</p>
    {% endfor %}
  </div>
</div>
