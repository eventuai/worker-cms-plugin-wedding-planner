<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ weddingHref }}">{{ weddingName }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ "wedding_planner.views.rundown.title" | t }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ "wedding_planner.views.rundown.subtitle" | t }}</p>
  </div>
  {% if newHref != blank %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700"
     title="{{ "wedding_planner.views.rundown.new_item" | t }}" aria-label="{{ "wedding_planner.views.rundown.new_item" | t }}" href="{{ newHref }}">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
    <span class="hidden lg:inline">{{ "wedding_planner.views.rundown.new_item" | t }}</span>
  </a>{% endif %}
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash | t }}</p>{% endif %}
{% if isEmpty %}
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-10 text-center">
    <p class="text-sm text-gray-500 mb-4">{{ "wedding_planner.views.rundown.no_items" | t }}</p>
    {% if generateAction != blank %}
      <form method="post" action="{{ generateAction }}" class="inline-block">
        <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit">{{ "wedding_planner.views.rundown.generate" | t }}</button>
      </form>
      <p class="text-xs text-gray-400 mt-3">{{ "wedding_planner.views.rundown.generate_hint" | t }}</p>
    {% endif %}
  </div>
{% else %}
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left relative">
      <thead class="bg-gray-50 border-b border-gray-200"><tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "wedding_planner.views.rundown.time" | t }}</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "wedding_planner.views.rundown.item" | t }}</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "wedding_planner.views.rundown.owner" | t }}</th>
        <th class="px-6 py-3"></th>
      </tr></thead>
      <tbody class="divide-y divide-gray-100">
        {% for item in items %}
          <tr>
            <td class="px-6 py-3 text-sm font-semibold text-gray-900 whitespace-nowrap">{{ item.time }}</td>
            <td class="px-6 py-3 text-sm text-gray-700">
              {% if item.editHref != blank %}<a class="hover:text-indigo-700" href="{{ item.editHref }}">{{ item.name }}</a>{% else %}{{ item.name }}{% endif %}
              {% if item.notes != blank %}<p class="text-xs text-gray-400 mt-1">{{ item.notes }}</p>{% endif %}
            </td>
            <td class="px-6 py-3 text-sm text-gray-500 whitespace-nowrap">{{ item.owner }}</td>
            <td class="px-6 py-3 text-right whitespace-nowrap">
              {% if item.deleteAction != blank %}
                <form method="post" action="{{ item.deleteAction }}" data-confirm="{{ "wedding_planner.views.rundown.confirm_delete" | t }}" class="inline-block">
                  <button class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-600 hover:bg-red-50 hover:text-red-700 cursor-pointer" type="submit" title="{{ "wedding_planner.views.rundown.delete_item" | t }}" aria-label="{{ "wedding_planner.views.rundown.delete_item" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg></button>
                </form>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}
