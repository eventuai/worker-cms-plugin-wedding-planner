<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "wedding_planner.views.wedding_new.back" | t }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ "wedding_planner.views.wedding_new.title" | t }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ "wedding_planner.views.wedding_new.subtitle" | t }}</p>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action }}">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.partner1" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="partner1" required></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.partner2" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="partner2" required></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.wedding_date" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="date" name="date" required></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.checklist_language" | t }}</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="language">
        {% for language in languages %}<option value="{{ language.value }}"{% if language.selected %} selected{% endif %}>{{ language.labelKey | t }}</option>{% endfor %}
      </select>
    </label>
    <fieldset class="mb-4">
      <legend class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.scope_question" | t }}</legend>
      <p class="text-xs text-gray-500 mb-2">{{ "wedding_planner.views.wedding_new.scope_hint" | t }}</p>
      <div class="grid grid-cols-2 gap-2">
        {% for scope in scopes %}
          <label class="flex items-center gap-2 rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700"><input type="checkbox" name="scope_{{ scope.key }}" value="yes"{% if scope.checked %} checked{% endif %}> {{ scope.labelKey | t }}</label>
        {% endfor %}
      </div>
    </fieldset>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "wedding_planner.views.wedding_new.total_budget" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="number" min="0" step="1" name="budget_total" placeholder="200000"><span class="block text-xs text-gray-500 mt-1">{{ "wedding_planner.views.wedding_new.budget_hint" | t }}</span></label>
    <label class="flex items-center gap-2 mb-4 text-sm text-gray-700"><input type="checkbox" name="seed" value="yes" checked> {{ "wedding_planner.views.wedding_new.seed_label" | t }}</label>
    <p class="text-xs text-gray-500 mb-4">{{ "wedding_planner.views.wedding_new.seed_hint" | t }}</p>
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
      {{ "wedding_planner.views.wedding_new.create" | t }}
    </button>
  </form>
</div>
