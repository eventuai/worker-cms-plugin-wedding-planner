<div class="mb-4">
  <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ weddingHref }}">{{ "wedding_planner.views.wedding_delete.back" | t }}</a>
  <h1 class="text-2xl font-bold text-gray-900">{{ "wedding_planner.views.wedding_delete.title" | t }} — {{ weddingName }}</h1>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <p class="text-sm text-gray-700 mb-3">{{ "wedding_planner.views.wedding_delete.warning" | t }}</p>
  <ul class="text-sm text-gray-500 mb-4 list-disc ps-4">
    <li>{{ taskCount }} {{ "wedding_planner.views.wedding_delete.tasks" | t }}</li>
    <li>{{ budgetCount }} {{ "wedding_planner.views.wedding_delete.budget_items" | t }}</li>
    <li>{{ rundownCount }} {{ "wedding_planner.views.wedding_delete.rundown_items" | t }}</li>
  </ul>
  <form method="post" action="{{ action }}" data-confirm="{{ "wedding_planner.views.wedding_delete.confirm_prompt" | t }}">
    <div class="flex items-center gap-3">
      <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-red-600 px-4 text-sm font-semibold text-white hover:bg-red-700 cursor-pointer" type="submit">{{ "wedding_planner.views.wedding_delete.confirm" | t }}</button>
      <a class="text-sm text-gray-500 hover:text-indigo-700" href="{{ weddingHref }}">{{ "wedding_planner.views.wedding_delete.cancel" | t }}</a>
    </div>
  </form>
</div>
